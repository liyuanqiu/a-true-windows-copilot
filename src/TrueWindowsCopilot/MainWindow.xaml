<Window
    x:Class="TrueWindowsCopilot.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:TrueWindowsCopilot.Models"
    xmlns:converters="using:TrueWindowsCopilot.Converters"
    xmlns:md="using:CommunityToolkit.WinUI.UI.Controls"
    Title="A True Windows Copilot">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <!-- Message template selector with 3 templates -->
            <converters:MessageTemplateSelector x:Key="MessageTemplateSelector">

                <converters:MessageTemplateSelector.UserTemplate>
                    <DataTemplate x:DataType="models:ChatMessage">
                        <Grid Margin="100,3,16,3" HorizontalAlignment="Right">
                            <Border CornerRadius="14,14,4,14"
                                    Padding="16,10"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    MaxWidth="620">
                                <TextBlock Text="{x:Bind Content, Mode=OneWay}"
                                           TextWrapping="Wrap"
                                           IsTextSelectionEnabled="True"
                                           Foreground="White" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </converters:MessageTemplateSelector.UserTemplate>

                <converters:MessageTemplateSelector.AssistantTemplate>
                    <DataTemplate x:DataType="models:ChatMessage">
                        <Grid Margin="16,3,100,3" HorizontalAlignment="Left">
                            <Border CornerRadius="14,14,14,4"
                                    Padding="16,10"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    MaxWidth="620">
                                <StackPanel>
                                    <md:MarkdownTextBlock Text="{x:Bind Content, Mode=OneWay}"
                                                          Background="Transparent"
                                                          IsTextSelectionEnabled="True"
                                                          WrapCodeBlock="True"
                                                          UseSyntaxHighlighting="True" />
                                    <Button HorizontalAlignment="Right"
                                            Margin="0,6,0,0"
                                            Padding="8,4"
                                            CornerRadius="6"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Tag="{x:Bind Content, Mode=OneWay}"
                                            Click="OnCopyMessageClick"
                                            ToolTipService.ToolTip="Copy to clipboard">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                                            <TextBlock Text="Copy" FontSize="12" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </converters:MessageTemplateSelector.AssistantTemplate>

                <converters:MessageTemplateSelector.ToolTemplate>
                    <DataTemplate x:DataType="models:ChatMessage">
                        <Grid Margin="16,2,100,2" HorizontalAlignment="Left">
                            <Border CornerRadius="8"
                                    Padding="12,8"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    MaxWidth="620">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE90F;" FontSize="14"
                                              Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                                    <TextBlock Text="{x:Bind Content, Mode=OneWay}"
                                               TextWrapping="Wrap"
                                               IsTextSelectionEnabled="True"
                                               FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </converters:MessageTemplateSelector.ToolTemplate>

            </converters:MessageTemplateSelector>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ Title Bar ═══ -->
        <Grid Grid.Row="0" Padding="20,14,20,10" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE799;" FontSize="22" Margin="0,0,12,0"
                          Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                <TextBlock Text="A True Windows Copilot"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <Button Click="OnNewChatClick"
                        ToolTipService.ToolTip="New Chat"
                        Style="{StaticResource SubtleButtonStyle}">
                    <FontIcon Glyph="&#xE710;" FontSize="15" />
                </Button>
                <Button Click="OnSettingsClick"
                        ToolTipService.ToolTip="Settings"
                        Style="{StaticResource SubtleButtonStyle}">
                    <FontIcon Glyph="&#xE713;" FontSize="15" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══ Messages ═══ -->
        <ListView Grid.Row="1"
                  x:Name="MessagesListView"
                  ItemsSource="{x:Bind ViewModel.Messages}"
                  ItemTemplateSelector="{StaticResource MessageTemplateSelector}"
                  SelectionMode="None"
                  Padding="0,8,0,8">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- ═══ Thinking Indicator ═══ -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="20,4,20,4"
                    Spacing="10"
                    Visibility="{x:Bind ViewModel.BusyVisibility, Mode=OneWay}">
            <ProgressRing IsActive="True" Width="18" Height="18" />
            <TextBlock Text="{x:Bind ViewModel.BusyText, Mode=OneWay}"
                       VerticalAlignment="Center"
                       FontSize="13"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- ═══ Input Area ═══ -->
        <Grid Grid.Row="3" Padding="16,8,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputTextBox"
                     Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Ask me anything about your Windows system..."
                     TextWrapping="Wrap"
                     AcceptsReturn="False"
                     MaxHeight="150"
                     KeyDown="OnInputKeyDown"
                     CornerRadius="10"
                     Padding="14,10" />

            <Button Grid.Column="1"
                    Margin="8,0,0,0"
                    Click="OnSendClick"
                    Style="{StaticResource AccentButtonStyle}"
                    VerticalAlignment="Bottom"
                    CornerRadius="10"
                    Padding="14,10"
                    IsEnabled="{x:Bind ViewModel.CanSend, Mode=OneWay}">
                <FontIcon Glyph="&#xE724;" FontSize="16" />
            </Button>
        </Grid>
    </Grid>
</Window>
