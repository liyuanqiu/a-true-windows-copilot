{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/TrueWindowsCopilot/TrueWindowsCopilot.csproj",
        "-c", "Debug",
        "-p:Platform=x64",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "build-release",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/TrueWindowsCopilot/TrueWindowsCopilot.csproj",
        "-c", "Release",
        "-p:Platform=x64",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "publish (x64)",
      "type": "shell",
      "command": "dotnet publish src/TrueWindowsCopilot/TrueWindowsCopilot.csproj -c Release -p:Platform=x64 -r win-x64 --self-contained; if ($LASTEXITCODE -eq 0) { $src = 'src/TrueWindowsCopilot/bin/x64/Release/net10.0-windows10.0.22621.0/win-x64/publish'; Remove-Item publish/win-x64 -Recurse -Force -ErrorAction SilentlyContinue; Copy-Item $src publish/win-x64 -Recurse; Write-Host \"Published to publish/win-x64/\" }",
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "publish (ARM64)",
      "type": "shell",
      "command": "dotnet publish src/TrueWindowsCopilot/TrueWindowsCopilot.csproj -c Release -p:Platform=ARM64 -r win-arm64 --self-contained; if ($LASTEXITCODE -eq 0) { $src = 'src/TrueWindowsCopilot/bin/ARM64/Release/net10.0-windows10.0.22621.0/win-arm64/publish'; Remove-Item publish/win-arm64 -Recurse -Force -ErrorAction SilentlyContinue; Copy-Item $src publish/win-arm64 -Recurse; Write-Host \"Published to publish/win-arm64/\" }",
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "publish + zip (x64)",
      "dependsOn": "publish (x64)",
      "type": "shell",
      "command": "Compress-Archive -Path ${workspaceFolder}/publish/win-x64/* -DestinationPath ${workspaceFolder}/publish/TrueWindowsCopilot-win-x64.zip -Force; Write-Host 'Created: publish/TrueWindowsCopilot-win-x64.zip'",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "publish + zip (ARM64)",
      "dependsOn": "publish (ARM64)",
      "type": "shell",
      "command": "Compress-Archive -Path ${workspaceFolder}/publish/win-arm64/* -DestinationPath ${workspaceFolder}/publish/TrueWindowsCopilot-win-arm64.zip -Force; Write-Host 'Created: publish/TrueWindowsCopilot-win-arm64.zip'",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "publish + zip (ALL)",
      "dependsOn": [
        "publish + zip (x64)",
        "publish + zip (ARM64)"
      ],
      "problemMatcher": [],
      "group": "build"
    }
  ]
}
